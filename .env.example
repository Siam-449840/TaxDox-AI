# ─────────────────────────────────────────────────────────────────────
# TaxDox AI — Environment template
# Copy to `.env` and fill in real values. NEVER commit real `.env`.
# Production boot fails loud (validateEnv) if any REQUIRED var is unset.
# ─────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/taxdox

# ── Auth (REQUIRED) ───────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000

# ── Security (REQUIRED) ───────────────────────────────────────────────
# PII AES-256-GCM key. Generate: openssl rand -base64 32
ENCRYPTION_KEY=change-me

# ── App (REQUIRED) ────────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ── Billing: Stripe (REQUIRED in prod) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# ── Cron (REQUIRED in prod) ───────────────────────────────────────────
# Shared secret for /api/cron/*. Generate: openssl rand -hex 32
CRON_API_KEY=change-me

# ── Object storage (OPTIONAL — local disk when STORAGE_DRIVER unset) ──
# STORAGE_DRIVER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# ── Email (OPTIONAL — log-only when EMAIL_DRIVER unset) ───────────────
# EMAIL_DRIVER=resend
# RESEND_API_KEY=
# FROM_EMAIL=TaxDox <noreply@example.com>

# ── Job queue (OPTIONAL — synchronous when INNGEST_* unset) ───────────
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# INNGEST_APP_URL=http://localhost:3000/api/inngest

# ── Rate limiting / idempotency (OPTIONAL — in-memory in dev) ─────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Error monitoring (OPTIONAL — no-op when unset) ────────────────────
# SENTRY_DSN=
